---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconCategory from "@/assets/icons/IconCategory.svg";
import config from "@/config";

type Props = {
  category: string;
  categoryName: string;
  size?: "sm" | "lg";
};

const { category, categoryName, size = "lg" } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `categories/${category}/`)}
    transition:name={category}
    class:list={[
      "flex items-center gap-0.5",
      "border-foreground border-b-2 border-dashed",
      "hover:border-accent hover:text-accent hover:-mt-0.5",
      "focus-visible:text-accent focus-visible:border-none",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconCategory
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {categoryName}
  </a>
</li>